# Aeterna runtime environment
# Rendered at install/upgrade time by ynh_config_add — tokens of the form
# (double-underscore) NAME (double-underscore) are substituted from the
# matching bash variables ($name) in the install script.
#
# Only env vars actually consumed by the v1.5.0 backend are listed here.
# The encryption key is NOT in this file; it lives at $data_dir/secrets/
# encryption_key (mode 0600) and is passed to the binary via the
# --encryption-key-file CLI flag in the systemd unit.

ENV=production

# Public URL the frontend assets call back to (used by the worker for
# embedding heartbeat / reveal links inside delivery + reminder emails).
BASE_URL=https://__DOMAIN____PATH__

# CORS allowlist. The backend's CORS middleware compares the Origin header
# against this exact string, so include scheme + host (no path).
ALLOWED_ORIGINS=https://__DOMAIN__

# Storage. The backend derives the uploads directory from dirname($DATABASE_PATH)
# (see backend/internal/services/file_service.go GetUploadsDir), so keeping
# the SQLite DB and uploads/ side-by-side under $data_dir is the only
# layout that works.
DATABASE_PATH=__DATA_DIR__/aeterna.db

# Webhook SSRF guard — leave blank to disallow user-defined webhooks calling
# any host, or set a comma-separated allowlist of hostnames once you trust
# specific destinations.
WEBHOOK_ALLOWLIST_HOSTS=

# Logging — the binary already emits JSON to stdout/stderr which systemd
# captures. LOG_FILE is intentionally unset so we don't double-write.
LOG_LEVEL=info
LOG_FORMAT=json
