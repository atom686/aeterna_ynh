#!/bin/bash
# =============================================================================
# CHANGE URL SCRIPT
# =============================================================================
# Aeterna's frontend bakes VITE_API_URL and the Vite --base into the JS
# bundle at build time, so a domain or path change requires us to:
#   1) re-render the nginx vhost (helper does this for us),
#   2) rebuild the frontend with the new path,
#   3) re-render the .env so BASE_URL / ALLOWED_ORIGINS reflect the new origin,
#   4) restart the backend.
# The Go binary itself doesn't need recompilation.

set -eu

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP THE SERVICE
#=================================================

ynh_script_progression "Stopping $app…"
ynh_systemctl --service="$app" --action="stop" --log_path="/var/log/$app/$app.log"

#=================================================
# NGINX
#=================================================

ynh_script_progression "Re-rendering nginx config…"
ynh_config_change_url_nginx

#=================================================
# REBUILD FRONTEND ONLY
#=================================================
# build_aeterna would also rebuild the Go backend, which is unnecessary
# here. Inline the frontend half to avoid the slow Go build.

ynh_script_progression "Rebuilding the frontend with the new URL…"

# Node was already provisioned by the manifest's [resources.nodejs] block
# at install time and the helpers' auto-loader has put it on $PATH for us.
# npm_config_cache is set explicitly because $HOME is unset in the YunoHost
# script context — see _common.sh build_aeterna for the same reason.
npm_workdir="$install_dir/.npm-build"
mkdir -p "$npm_workdir"

pushd "$install_dir/frontend" >/dev/null
    env VITE_API_URL="${path%/}/api" \
        npm_config_cache="$npm_workdir" \
        npm ci
    env VITE_API_URL="${path%/}/api" \
        npm_config_cache="$npm_workdir" \
        npm run build -- --base="${path%/}/"
popd >/dev/null

ynh_safe_rm "$install_dir/frontend/node_modules"
ynh_safe_rm "$npm_workdir"

# vite wrote dist/* as root — reset to aeterna:www-data so nginx can
# read the new bundle.
chown -R "$app:www-data" "$install_dir/frontend/dist"

#=================================================
# RE-RENDER .env
#=================================================
# BASE_URL and ALLOWED_ORIGINS depend on the new domain/path.

ynh_config_add --template="aeterna.env" --destination="$install_dir/.env"
chmod 600 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

#=================================================
# START
#=================================================

ynh_script_progression "Starting $app…"
ynh_systemctl --service="$app" --action="start" \
    --log_path="/var/log/$app/$app.log" \
    --wait_until="Fiber v" \
    --timeout=120

ynh_script_progression "URL change for $app completed."
