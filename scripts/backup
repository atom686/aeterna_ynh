#!/bin/bash
# =============================================================================
# BACKUP SCRIPT
# =============================================================================
# Read-only declarations only — `ynh_backup` lists what to copy; the core
# does the actual copying. Keep this fast and side-effect-free.
#
# Note on $data_dir and /var/log/$app: ynh_backup auto-detects these by path
# and SKIPS them during the safety-backup-before-upgrade (only includes them
# in user-initiated backups). That's the upstream design — too heavy to
# include in every upgrade safety net. So declaring them here is correct;
# they'll appear in `yunohost backup create` archives but get skipped on
# the safety-net path.

set -eu

# Resolve the script's own directory so `source _common.sh` works
# regardless of the caller's cwd. The safety-backup pre-upgrade
# invokes this script via absolute path with no cd into scripts/.
cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# APPLICATION CODE + BUILT ARTIFACTS
#=================================================

ynh_script_progression "Backing up the install dir…"
ynh_backup "$install_dir"

#=================================================
# USER DATA
#=================================================
# CRITICAL: $data_dir contains the encryption key alongside the DB and
# attachments. Without the key, the backed-up DB is unreadable on restore,
# so they MUST travel together (skipped during safety-backup, included in
# user-initiated backups — see header note).

ynh_script_progression "Backing up the data dir…"
ynh_backup "$data_dir"

#=================================================
# LOGS
#=================================================

ynh_backup "/var/log/$app"

#=================================================
# SERVER CONFIGURATION
#=================================================

ynh_backup "/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_backup "/etc/systemd/system/$app.service"

ynh_script_progression "Backup of $app completed."
