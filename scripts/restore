#!/bin/bash
# =============================================================================
# RESTORE SCRIPT
# =============================================================================

set -eu

# Resolve the script's own directory so `source _common.sh` works
# regardless of the caller's cwd. See scripts/install for full context.
cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# RESTORE FILES
#=================================================
# v2.1's ynh_restore takes a positional path; there's no --not_mandatory
# flag. The helper auto-detects $data_dir and /var/log/$app (anything
# matching is_data=true) and silently skips them if they're absent in
# the archive — which is exactly what happens when restoring from a
# safety-backup-before-upgrade since those paths weren't included.

ynh_script_progression "Restoring the install dir…"
ynh_restore "$install_dir"

ynh_script_progression "Restoring the data dir…"
ynh_restore "$data_dir"

ynh_script_progression "Restoring logs…"
ynh_restore "/var/log/$app"

ynh_script_progression "Restoring nginx + systemd configuration…"
ynh_restore "/etc/nginx/conf.d/$domain.d/$app.conf"
ynh_restore "/etc/systemd/system/$app.service"

#=================================================
# RE-ASSERT OWNERSHIP + PERMS
#=================================================
# Backup archives may have been built on another host; uid/gid mapping
# can drift, so we re-set the canonical perms from scratch.
#
# install_dir gets aeterna:www-data so nginx can read frontend/dist/*.
# .env is then re-locked tighter to aeterna:aeterna 600 so nginx and
# anyone else can't read SMTP creds / encryption-key path / etc.
chown -R "$app:www-data" "$install_dir"
chown "$app:$app" "$install_dir/.env" 2>/dev/null || true
chmod 600 "$install_dir/.env" 2>/dev/null || true

# data_dir and logs aren't served by nginx — keep them aeterna:aeterna.
chown -R "$app:$app" "$data_dir"
chown -R "$app:$app" "/var/log/$app"
chmod 700 "$data_dir/secrets" 2>/dev/null || true
chmod 600 "$data_dir/secrets/encryption_key" 2>/dev/null || true

#=================================================
# RE-REGISTER + START
#=================================================

systemctl daemon-reload

yunohost service add "$app" \
    --description="Aeterna dead man's switch backend" \
    --log="/var/log/$app/$app.log"

ynh_script_progression "Starting $app…"
ynh_systemctl --service="$app" --action="start" \
    --log_path="/var/log/$app/$app.log" \
    --wait_until="Fiber v" \
    --timeout=120

ynh_systemctl --service="nginx" --action="reload"

ynh_script_progression "Restore of $app completed."
